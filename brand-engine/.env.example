# brand-engine .env.example
# Copy to .env and fill in real values. Never commit .env.
# Last canonical review: 2026-04-17.

# ─── Sidecar server ──────────────────────────────────────────────────────────
BRAND_ENGINE_PORT=8100

# ─── Supabase (shared with os-api) ───────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-or-anon-key>

# ─── Pinecone (brand asset vector index) ─────────────────────────────────────
PINECONE_API_KEY=<pinecone-key>

# ─── Vertex AI — video QA (video_grader.py) ──────────────────────────────────
# Application Default Credentials via:
#   gcloud auth application-default login
# or a service-account JSON at GOOGLE_APPLICATION_CREDENTIALS.
# Project + region must match the orchestrator's vertex-sdk config.
VERTEX_PROJECT_ID=bran-479523
VERTEX_REGION=global
# Override the video-QA model id if tracking a successor to gemini-3.1-pro-001
# GEMINI_VIDEO_CRITIC_MODEL=gemini-3.1-pro-001

# ─── Gemini AI Studio — embeddings (embeddings.py, not yet migrated) ────────
# Still used by brand_engine/core/embeddings.py for text/image embeddings.
# Migration to Vertex tracked in ~/agent-vault/briefs/temp-gen-vertex-image-migration.md
# (same credential pattern; separate brief because embeddings uses a different model family).
GOOGLE_GENAI_API_KEY=<ai-studio-api-key>
# Alternative name the google-genai SDK also accepts:
# GEMINI_API_KEY=<same-key-as-above>

# ─── AWS Bedrock — Cohere embeddings (embeddings.py alt path) ───────────────
AWS_ACCESS_KEY_ID=<aws-key>
AWS_SECRET_ACCESS_KEY=<aws-secret>
AWS_DEFAULT_REGION=us-east-2
# AWS_SESSION_TOKEN=<optional-if-using-assume-role>
# COHERE_API_KEY=<only-if-using-cohere-direct-api-instead-of-bedrock>
