# brand-engine .env.example
# Copy to .env and fill in real values. Never commit .env.
# Last canonical review: 2026-04-17.

# ─── Sidecar server ──────────────────────────────────────────────────────────
BRAND_ENGINE_PORT=8100

# ─── Supabase (shared with os-api) ───────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service-role-or-anon-key>

# ─── Pinecone (brand asset vector index) ─────────────────────────────────────
PINECONE_API_KEY=<pinecone-key>

# ─── Video QA (video_grader.py) — backend selection ──────────────────────────
# Two backends: `ai_studio` (default) and `vertex`.
# Stay on ai_studio until bran-479523 gets Gemini 3 Vertex preview access.
GEMINI_VIDEO_CRITIC_BACKEND=ai_studio
# GEMINI_VIDEO_CRITIC_AI_STUDIO_MODEL=gemini-3.1-pro-preview
# GEMINI_VIDEO_CRITIC_VERTEX_MODEL=gemini-3-pro-preview

# ─── Vertex AI — used when GEMINI_VIDEO_CRITIC_BACKEND=vertex ───────────────
VERTEX_PROJECT_ID=bran-479523
VERTEX_REGION=global
# Auth for the vertex backend:
#   1. Primary: Application Default Credentials for an account with
#      aiplatform.user role on bran-479523 — i.e.
#        gcloud auth application-default login --account tim@brandstudios.ai
#      ADC caches a refresh token at
#      ~/.config/gcloud/application_default_credentials.json and regenerates
#      short-lived access tokens automatically (no rotation).
#   2. Alt: GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
#      for durable / headless / server deployments.
#
# Note: VERTEX_API_KEY (Vertex Express Mode) is NOT suitable here — Express keys
# are bound to a specific GCP project and region at issue time, so a key
# created for project X in region us-west4 cannot reach bran-479523/global.
# The os-api orchestrator can use it because @anthropic-ai/vertex-sdk
# constructs URLs from caller-supplied project+region; google-genai's Vertex
# client with api_key= defers to the key's bound project/region.
# Override the video-QA model id if tracking a successor to gemini-3.1-pro-001
# GEMINI_VIDEO_CRITIC_MODEL=gemini-3.1-pro-001

# ─── Gemini AI Studio — embeddings (embeddings.py, not yet migrated) ────────
# Still used by brand_engine/core/embeddings.py for text/image embeddings.
# Migration to Vertex tracked in ~/agent-vault/briefs/temp-gen-vertex-image-migration.md
# (same credential pattern; separate brief because embeddings uses a different model family).
GOOGLE_GENAI_API_KEY=<ai-studio-api-key>
# Alternative name the google-genai SDK also accepts:
# GEMINI_API_KEY=<same-key-as-above>

# ─── AWS Bedrock — Cohere embeddings (embeddings.py alt path) ───────────────
AWS_ACCESS_KEY_ID=<aws-key>
AWS_SECRET_ACCESS_KEY=<aws-secret>
AWS_DEFAULT_REGION=us-east-2
# AWS_SESSION_TOKEN=<optional-if-using-assume-role>
# COHERE_API_KEY=<only-if-using-cohere-direct-api-instead-of-bedrock>
