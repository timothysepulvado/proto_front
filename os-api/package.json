{
  "name": "brandstudios-os-api",
  "version": "0.1.0",
  "description": "BrandStudios OS orchestration API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:phase4-cache-stability": "tsx tests/_phase4-cache-stability.ts",
    "test:phase4-review-gate-card": "tsx tests/_phase4-review-gate-card.ts",
    "test:phase4-reject-teach": "tsx tests/_phase4-reject-teach.ts",
    "test:phase4-reject-race": "tsx tests/_phase4-reject-race.ts",
    "test:phase7-multi-tenant-isolation": "tsx tests/_phase7-multi-tenant-isolation.ts",
    "test:pr4-storage-and-ledger": "tsx tests/_pr4-storage-and-ledger.ts",
    "test:asset-integrity": "tsx tests/_asset-integrity.ts",
    "test:merge-gate": "npm run test:phase4-cache-stability && npm run test:phase4-review-gate-card && npm run test:phase4-reject-teach && npm run test:phase4-reject-race && npm run test:phase7-multi-tenant-isolation && npm run test:pr4-storage-and-ledger && npm run test:asset-integrity"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "@supabase/supabase-js": "^2.90.1",
    "cloudinary": "2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "9.0.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "9.0.6",
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
