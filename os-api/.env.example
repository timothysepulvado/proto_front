# BrandStudios OS API Configuration

# Server
PORT=3001

# Supabase (required — single source of truth for all data)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_publishable_key

# Paths to external repos (adjust to your local setup)
TEMP_GEN_PATH=/Users/timothysepulvado/Temp-gen
BRAND_LINTER_PATH=/Users/timothysepulvado/Brand_linter/local_quick_setup

# Python virtual environment paths (optional, uses system python if not set)
TEMP_GEN_VENV=/Users/timothysepulvado/Temp-gen/.venv
BRAND_LINTER_VENV=/Users/timothysepulvado/Brand_linter/local_quick_setup/.venv

# Pinecone (for Brand Memory indexing)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1

# Gemini (for image/video generation)
GEMINI_API_KEY=your_gemini_api_key

# Vertex AI — Claude Opus 4.7 orchestrator (decides escalation L1/L2/L3 actions)
# First-client infra runs Claude via Google Cloud Vertex AI, NOT the direct
# Anthropic API. Requires either VERTEX_API_KEY as an OAuth access token OR
# Google Application Default Credentials (GOOGLE_APPLICATION_CREDENTIALS /
# gcloud auth application-default login).
VERTEX_PROJECT_ID=bran-479523
VERTEX_REGION=global
# If using an access token directly (e.g. from `gcloud auth print-access-token`):
VERTEX_API_KEY=your_vertex_access_token
# Optional — override orchestrator model id (default: claude-opus-4-7 — unsuffixed for Vertex)
# CLAUDE_ORCHESTRATOR_MODEL=claude-opus-4-7
# Optional — override pricing for cost estimates (USD per million tokens)
# CLAUDE_INPUT_COST_PER_M=15.00
# CLAUDE_OUTPUT_COST_PER_M=75.00

# Google (used by brand-engine /grade_video for Gemini 3.1 Pro video critic)
# GOOGLE_API_KEY=your_google_api_key
# GEMINI_VIDEO_CRITIC_MODEL=gemini-3-pro

# Brand Engine + Temp-gen FastAPI sidecars (HTTP)
BRAND_ENGINE_URL=http://localhost:8100
TEMP_GEN_URL=http://localhost:8200
