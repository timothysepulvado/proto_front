# BrandStudios OS API Configuration

# Server
PORT=3001

# Supabase (required — single source of truth for all data)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here

# Client-scoped JWT minting for direct HUD Supabase reads (default off)
JWT_AUTH_ENABLED=false
SUPABASE_JWT_SECRET=replace_with_supabase_jwt_secret_when_enabling

# Paths to external repos (adjust to your local setup)
TEMP_GEN_PATH=/Users/timothysepulvado/Temp-gen
BRAND_LINTER_PATH=/Users/timothysepulvado/Brand_linter/local_quick_setup

# Python virtual environment paths (optional, uses system python if not set)
TEMP_GEN_VENV=/Users/timothysepulvado/Temp-gen/.venv
BRAND_LINTER_VENV=/Users/timothysepulvado/Brand_linter/local_quick_setup/.venv

# Pinecone (for Brand Memory indexing)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1

# Gemini (for image/video generation)
GEMINI_API_KEY=your_gemini_api_key

# Claude Opus 4.7 orchestrator (decides escalation L1/L2/L3 actions)
#
# ── Backend selection (2026-04-19 pivot — direct Anthropic is now PRIMARY) ──
# Set ANTHROPIC_API_KEY → direct @anthropic-ai/sdk (primary). Unset it → Vertex
# fallback (auto). `getAnthropicClient()` picks per-env at module load.
#
# 1. PRIMARY — Direct Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key
#
# 2. FALLBACK — Vertex AI on bran-479523. Fully wired; reactivates by
#    unsetting ANTHROPIC_API_KEY above. Vertex auth precedence (SA key
#    recommended for headless safety):
#      a. GOOGLE_APPLICATION_CREDENTIALS — service-account JSON path.
#         Headless-safe; no `invalid_rapt` reauth churn. PREFERRED.
#      b. VERTEX_API_KEY — OAuth access token (short-lived; dev only).
#      c. Bare ADC — whatever `gcloud auth application-default login` set.
#    (Vertex Claude Opus 4.7 regional quota on bran-479523 is 0; approval
#    request submitted 2026-04-18, pending ~days. Not blocking anything
#    while direct path is active.)
VERTEX_PROJECT_ID=bran-479523
VERTEX_REGION=global
# Recommended for Vertex: service-account JSON. Create SA in bran-479523
# with role `roles/aiplatform.user`, download key, chmod 600, store outside repo.
GOOGLE_APPLICATION_CREDENTIALS=/Users/timothysepulvado/agent-vault/secrets/vertex-anthropic-bran-479523.json
# Legacy/dev Vertex: short-lived OAuth access token.
# VERTEX_API_KEY=your_vertex_access_token
# Optional — override orchestrator model id
# CLAUDE_ORCHESTRATOR_MODEL=claude-opus-4-7
# Optional — override pricing for cost estimates (USD per million tokens).
# Defaults match Opus 4.7 list price as of 2026-04-19. Override only if
# Anthropic changes billing or you're pointing at a different model.
# CLAUDE_INPUT_COST_PER_M=5.00
# CLAUDE_OUTPUT_COST_PER_M=25.00

# Google (used by brand-engine /grade_video for Gemini 3.1 Pro video critic)
# GOOGLE_API_KEY=your_google_api_key
# GEMINI_VIDEO_CRITIC_MODEL=gemini-3-pro

# Brand Engine + Temp-gen FastAPI sidecars (HTTP)
BRAND_ENGINE_URL=http://localhost:8100
TEMP_GEN_URL=http://localhost:8200
